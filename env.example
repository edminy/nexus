# Agent 运行时 Provider 以 Settings 页面中的 Provider 表为准。
# 不再通过环境变量配置 Provider 的 auth_token / base_url / model。


# App Configuration
HOST=0.0.0.0
PORT=8010
DEBUG=true
LOG_LEVEL=debug
LOG_FORMAT=pretty
LOG_STDOUT=true
LOG_FILE_ENABLED=true
LOG_PATH=~/.nexus/logs/logger.log
LOG_ROTATE_DAILY=true
LOG_MAX_SIZE_MB=10
LOG_MAX_AGE_DAYS=7
LOG_MAX_BACKUPS=7
LOG_COMPRESS=true
MESSAGE_DEBUG_STREAM_EVENT=false
DATABASE_DRIVER=sqlite
DATABASE_URL=~/.nexus/data/nexus.db
WORKSPACE_PATH=
# nxs 记忆维护由 Nexus 唤醒；阈值和最终执行资格仍由 nxs settings 决定。
MEMORY_MAINTENANCE_MAX_CONCURRENT=2
MEMORY_MAINTENANCE_RUN_TIMEOUT_SECONDS=3600
MEMORY_MAINTENANCE_SWEEP_SECONDS=600
# 默认使用 npm 官方 registry，这样 `pnpm audit` 才能直接工作；如需镜像源可按环境覆盖。
PNPM_REGISTRY=https://registry.npmjs.org/
# Community Skill Sources
# SKILLS_SOURCE_URLS 支持逗号/分号/换行分隔；每项可写成 "名称|URL"。
# URL 可指向 agentskills.json/普通索引 JSON、Git 仓库、raw SKILL.md 或 zip。
# 默认会启用 claude-plugins.dev、skills.sh、clawhub.ai、browse.sh，并展示可选 Hermes Skills Index。
SKILLS_DEFAULT_SOURCES_ENABLED=true
SKILLS_API_URL=https://skills.sh
SKILLS_API_SEARCH_LIMIT=20
SKILLS_SOURCE_URLS=

# Browser Login / Public Deployment
# 服务启动时会自动执行数据库迁移，并在设置以下变量后自动确保存在一个 owner/admin；
# 如果库里已经存在 active 的 owner/admin，则会自动跳过。
AUTH_INIT_OWNER_USERNAME=admin
AUTH_INIT_OWNER_DISPLAY_NAME=
AUTH_INIT_OWNER_PASSWORD=
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_COOKIE_NAME=nexus_session
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
ACCESS_TOKEN=

# Channel Configuration
# 推荐在 Web UI 的「能力 / IM 通道」里配置机器人凭据；下面两个环境变量仅保留为系统级兼容入口。
DISCORD_ENABLED=true
DISCORD_BOT_TOKEN=
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=

# WebSocket Origin Configuration
# 限制 WebSocket 握手允许的 Origin 列表，多个值用逗号分隔。
# 支持通配符模式，例如 "localhost:*", "app://*", "nexus://*"。
# 留空时允许所有来源（向后兼容，不推荐生产环境使用）。
ALLOWED_WEBSOCKET_ORIGINS=

# Connector OAuth Configuration
# 必须与各 provider 开发者后台登记的回调 URI 完全一致。
CONNECTOR_OAUTH_REDIRECT_URI=http://localhost:3000/capability/connectors/oauth/callback
# 允许 OAuth redirect_uri 的 scheme+host+path 前缀，多个值用逗号分隔。
CONNECTOR_OAUTH_ALLOWED_ORIGINS=http://localhost:3000
# OAuth state 有效期，单位秒。
CONNECTOR_OAUTH_STATE_TTL_SECONDS=600
# 32 字节随机值的标准 base64，用于加密 connector / IM 通道凭据。
# 源码部署可用 `openssl rand -base64 32` 生成；Docker 部署留空时会自动生成并持久化。
CONNECTOR_CREDENTIALS_KEY=
# 可选：服务端出站代理。个人微信 iLink、企业微信、飞书、钉钉、Telegram、Discord 和 OAuth token 交换等后端请求会读取标准 proxy 环境变量。
# 例如：HTTPS_PROXY=http://host.docker.internal:7890
# Docker 部署复用宿主本地代理时，可直接填 127.0.0.1；入口脚本默认会改写到 host.docker.internal。
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,nexus,nginx
# Docker 容器需要和桌面 App 不同的路径或代理时，优先设置 NEXUS_DOCKER_* 覆盖项。
NEXUS_DOCKER_DATABASE_URL=
NEXUS_DOCKER_HTTP_PROXY=
NEXUS_DOCKER_HTTPS_PROXY=
NEXUS_DOCKER_ALL_PROXY=
NEXUS_DOCKER_NO_PROXY=

# Docker / Nginx SSL
# 没有证书文件时 nginx 会自动保持 HTTP；证书存在后启用 HTTPS。
HOST_DATA_DIR=./data
HTTP_PORT=80
HTTPS_PORT=443
NGINX_SERVER_NAME=_
NGINX_SSL_CERTIFICATE=/etc/nginx/certs/live/example.com/fullchain.pem
NGINX_SSL_CERTIFICATE_KEY=/etc/nginx/certs/live/example.com/privkey.pem
NGINX_REDIRECT_HTTPS=true
SSL_DOMAINS=
SSL_EMAIL=
SSL_CERT_NAME=
SSL_FORCE_RENEWAL=false
SSL_STAGING=false
SSL_RELOAD_NGINX=true
CERTBOT_IMAGE=certbot/certbot:latest

# 以下 *_CLIENT_ID / *_CLIENT_SECRET 填了会作为全局默认凭据；
# 留空时用户可在 Web UI "配置 OAuth 应用" 弹窗里自己填（本地开发推荐这种方式）。
# Dev 环境 callback 必须登记为: http://localhost:3000/capability/connectors/oauth/callback
# Prod 环境 callback 必须登记为: https://<your-domain>/capability/connectors/oauth/callback
CONNECTOR_GITHUB_CLIENT_ID=
CONNECTOR_GITHUB_CLIENT_SECRET=
CONNECTOR_GOOGLE_CLIENT_ID=
CONNECTOR_GOOGLE_CLIENT_SECRET=
CONNECTOR_LINKEDIN_CLIENT_ID=
CONNECTOR_LINKEDIN_CLIENT_SECRET=
CONNECTOR_TWITTER_CLIENT_ID=
CONNECTOR_TWITTER_CLIENT_SECRET=
CONNECTOR_INSTAGRAM_CLIENT_ID=
CONNECTOR_INSTAGRAM_CLIENT_SECRET=
CONNECTOR_SHOPIFY_CLIENT_ID=
CONNECTOR_SHOPIFY_CLIENT_SECRET=
# 注：以上 5 个 provider 当前在 catalog 中标记为 coming_soon，填了也不会在 UI 上架。
